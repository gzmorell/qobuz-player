{
  "app-id": "io.github.sofusa.QobuzPlayer",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "qobuz-player-gtk",

  "finish-args": [
    "--share=network",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri"
  ],

  "modules": [
    {
      "name": "qobuz-player-gtk",
      "buildsystem": "simple",
      "subdir": "qobuz-player-gtk",

      "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "build-args": ["--share=network"]
      },

      "build-commands": [
        "cargo install --locked --path . --root /app",

        "install -Dm644 ../qobuz-player-web/assets/favicon.svg /app/share/icons/hicolor/scalable/apps/io.github.sofusa.QobuzPlayer.svg",
        "install -Dm644 flatpak/io.github.sofusa.QobuzPlayer.desktop /app/share/applications/io.github.sofusa.QobuzPlayer.desktop",
        "install -Dm644 ../assets/qobuz-player-gtk.png /app/share/metainfo/qobuz-player-gtk.png",
        "install -Dm644 flatpak/io.github.sofusa.QobuzPlayer.metainfo.xml /app/share/metainfo/io.github.sofusa.QobuzPlayer.metainfo.xml"
      ],

      "sources": [
        {
          "type": "dir",
          "path": "../../"
        }
      ]
    }
  ]
}
